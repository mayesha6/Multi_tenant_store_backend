generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String?
  phone    String?
  picture  String?
  address  String?
  tenantId String?

  isDeleted  Boolean  @default(false)
  isActive   IsActive @default(ACTIVE)
  isVerified Boolean  @default(false)

  role UserRole @default(VIEWER)

  auths Auth[]

  assignedConversations Conversation[] @relation("ConversationAssignedUser")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
}

model Auth {
  id         String       @id @default(uuid())
  provider   AuthProvider
  providerId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model Content {
  id          String      @id @default(uuid())
  type        ContentType
  title       String
  content     String      @db.Text
  image       String?
  order       Int         @default(0)
  isPublished Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id       String   @id @default(cuid())
  name     String   @unique
  price    Float
  currency String   @default("USD")
  interval Interval
  features Json
  isActive Boolean  @default(true)

  stripeProductId String @unique
  stripePriceId   String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Channel {
  id       String      @id @default(uuid())
  tenantId String
  type     ChannelType
  apiKey   String
  settings Json?
  isActive Boolean     @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id       String        @id @default(uuid())
  tenantId String
  name     String
  email    String?
  phone    String?
  picture  String?
  address  String?
  status   ContactStatus @default(ACTIVE)
  source   ContactSource @default(MANUAL)
  tags     String[] 
  metadata Json?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model Conversation {
  id              String              @id @default(uuid())
  tenantId        String
  contactId       String
  subject         String?
  status          ConversationStatus  @default(OPEN)
  channel         ConversationChannel
  assignedToId    String?
  unreadCount     Int                 @default(0)
  lastMessageAt   DateTime?
  lastMessageText String?
  lastMessageType MessageType?
  isAiHandled     Boolean             @default(false)
  isDeleted       Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  contact    Contact   @relation(fields: [contactId], references: [id])
  assignedTo User?     @relation("ConversationAssignedUser", fields: [assignedToId], references: [id])
  messages   Message[]
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?

  @@index([tenantId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
   @@index([lastMessageAt])
}

model Message {
  id                String                @id @default(uuid())
  tenantId          String
  conversationId    String
  senderType        MessageSenderType
  direction         MessageDirection
  type              MessageType           @default(TEXT)
  content           String?
  externalMessageId String?
  deliveryStatus    MessageDeliveryStatus @default(SENT)
  metadata          Json?
  isDeleted         Boolean               @default(false)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  conversation      Conversation          @relation(fields: [conversationId], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([externalMessageId])
  @@index([createdAt])

  @@unique([tenantId, externalMessageId])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  type      String
  content   String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id               String  @id @default(uuid())
  name             String
  slug             String  @unique
  stripeCustomerId String? @unique

  industry   String?
  teamSize   String?
  websiteUrl String?

  onboardingStep      Int     @default(1)
  onboardingCompleted Boolean @default(false)

  isActive      Boolean @default(false)
  currentPlanId String?
  currentSubId  String?

  users         User[]
  subscriptions Subscription[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  channels      Channel[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
}

model Subscription {
  id               String             @id @default(cuid())
  tenantId         String
  planId           String
  stripeSubId      String             @unique
  stripeCustomerId String
  status           SubscriptionStatus
  startDate        DateTime
  endDate          DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model MessageWebhookEvent {
  id            String   @id @default(uuid())
  eventId       String   @unique
  type          String
  source        String?  // stripe / whatsapp / email / instagram etc
  status        String   @default("PENDING") // PENDING / SUCCESS / FAILED
  payload       Json
  errorMessage  String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
enum UserRole {
  ADMIN
  SUPER_ADMIN
  VIEWER
  AGENT
  OWNER
  SUPPORT
}

enum IsActive {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuthProvider {
  google
  credentials
}

enum ContentType {
  privacy
  terms
  about
  refund
  cookie
  shipping
  disclaimer
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELED
  PAID
}

enum Interval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  TELEGRAM
  EMAIL
  SMS
  WEBSITE_WIDGET
}

enum MessageSenderType {
  CUSTOMER
  AGENT
  AI
  SYSTEM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  VIDEO
  SYSTEM
}

enum MessageDeliveryStatus {
  SENT
  DELIVERED
  SEEN
  FAILED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ConversationChannel {
  WHATSAPP
  EMAIL
  INSTAGRAM
  FACEBOOK
  WEB
}


enum ContactStatus {
  ACTIVE
  BLOCKED
  LEAD
  CUSTOMER
}

enum ContactSource {
  MANUAL
  WHATSAPP
  EMAIL
  INSTAGRAM
  FACEBOOK
  IMPORT
}