model Tenant {
  id               String  @id @default(uuid())
  name             String
  slug             String  @unique
  isActive         Boolean @default(false) // CHANGED: depends on subscription
  stripeCustomerId String? @unique // ADDED: required for Stripe
  planId           String? // CHANGED: current active plan
  subscriptionId   String? // ADDED: current active subscription

  users         User[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  apiKey    String
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id              String   @id @default(uuid())
  tenantId        String
  contactId       String
  status          String
  assignedAgentId String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderType     String
  content        String
  createdAt      DateTime @default(now())
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  type      String
  content   String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
  VIEWER
  AGENT
  OWNER
}

enum IsActive {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuthProvider {
  google
  credentials
}

enum ContentType {
  privacy
  terms
  about
  refund
  cookie
  shipping
  disclaimer
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELED
  PAID
}

enum Interval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}
